// Basic rules - tighten before production
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == uid && !('role' in request.resource.data);
    }

    match /bills/{billId} {
      allow read: if isAdmin() || resource.data.issuedToUid == request.auth.uid;
      allow create: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.resource.data.status == 'paid' &&
          resource.data.issuedToUid == request.auth.uid &&
          request.resource.data.amount == resource.data.amount &&
          request.resource.data.referenceNumber == resource.data.referenceNumber
        )
      );
    }

    // TODO: add accounts, transactions, portfolios, cards, loans with granular rules
  }
}
